{
  "name": "@rail-schematic-viz/layout",
  "version": "0.1.0",
  "description": "Layout and interaction package for Rail Schematic Viz.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./layout": {
      "types": "./dist/layout/index.d.ts",
      "import": "./dist/layout/index.js",
      "require": "./dist/layout/index.cjs"
    },
    "./viewport": {
      "types": "./dist/viewport/index.d.ts",
      "import": "./dist/viewport/index.js",
      "require": "./dist/viewport/index.cjs"
    },
    "./interactions": {
      "types": "./dist/interactions/index.d.ts",
      "import": "./dist/interactions/index.js",
      "require": "./dist/interactions/index.cjs"
    },
    "./minimap": {
      "types": "./dist/minimap/index.d.ts",
      "import": "./dist/minimap/index.js",
      "require": "./dist/minimap/index.cjs"
    },
    "./performance": {
      "types": "./dist/performance/index.d.ts",
      "import": "./dist/performance/index.js",
      "require": "./dist/performance/index.cjs"
    },
    "./animation": {
      "types": "./dist/animation/index.d.ts",
      "import": "./dist/animation/index.js",
      "require": "./dist/animation/index.cjs"
    },
    "./accessibility": {
      "types": "./dist/accessibility/index.d.ts",
      "import": "./dist/accessibility/index.js",
      "require": "./dist/accessibility/index.cjs"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "import": "./dist/validation/index.js",
      "require": "./dist/validation/index.cjs"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js",
      "require": "./dist/errors/index.cjs"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "@rail-schematic-viz/core": "^0.1.0"
  },
  "devDependencies": {
    "@rail-schematic-viz/core": "file:../..",
    "@types/node": "^24.5.2",
    "fast-check": "^4.3.0",
    "tsup": "^8.5.0",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4"
  }
}
