{
  "name": "@rail-schematic-viz/adapters-shared",
  "version": "0.1.0",
  "description": "Shared adapter contracts and utilities for Rail Schematic Viz.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "browser": "./dist/index.umd.js",
  "unpkg": "./dist/index.umd.js",
  "jsdelivr": "./dist/index.umd.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js",
      "require": "./dist/events/index.cjs"
    },
    "./lifecycle": {
      "types": "./dist/lifecycle/index.d.ts",
      "import": "./dist/lifecycle/index.js",
      "require": "./dist/lifecycle/index.cjs"
    },
    "./export": {
      "types": "./dist/export/index.d.ts",
      "import": "./dist/export/index.js",
      "require": "./dist/export/index.cjs"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js",
      "require": "./dist/errors/index.cjs"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && node ../../scripts/generate-umd.mjs",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "license": "MIT",
  "homepage": "https://rail-schematic-viz.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/rail-schematic-viz/rail-schematic-viz.git",
    "directory": "packages/adapters-shared"
  },
  "bugs": {
    "url": "https://github.com/rail-schematic-viz/rail-schematic-viz/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@rail-schematic-viz/core": "^0.1.0",
    "@rail-schematic-viz/layout": "^0.1.0",
    "@rail-schematic-viz/overlays": "^0.1.0"
  },
  "devDependencies": {
    "@rail-schematic-viz/core": "file:../..",
    "@rail-schematic-viz/layout": "file:../layout",
    "@rail-schematic-viz/overlays": "file:../overlays",
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "fast-check": "^4.3.0",
    "tsup": "^8.5.0",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4"
  }
}
