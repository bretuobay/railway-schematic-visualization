{
  "name": "@rail-schematic-viz/overlays",
  "version": "0.1.0",
  "description": "Data visualization overlays for Rail Schematic Viz.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.cjs"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js",
      "require": "./dist/errors/index.cjs"
    },
    "./registry": {
      "types": "./dist/registry/index.d.ts",
      "import": "./dist/registry/index.js",
      "require": "./dist/registry/index.cjs"
    },
    "./manager": {
      "types": "./dist/manager/index.d.ts",
      "import": "./dist/manager/index.js",
      "require": "./dist/manager/index.cjs"
    },
    "./overlays": {
      "types": "./dist/overlays/index.d.ts",
      "import": "./dist/overlays/index.js",
      "require": "./dist/overlays/index.cjs"
    },
    "./rendering": {
      "types": "./dist/rendering/index.d.ts",
      "import": "./dist/rendering/index.js",
      "require": "./dist/rendering/index.cjs"
    },
    "./colors": {
      "types": "./dist/colors/index.d.ts",
      "import": "./dist/colors/index.js",
      "require": "./dist/colors/index.cjs"
    },
    "./spatial": {
      "types": "./dist/spatial/index.d.ts",
      "import": "./dist/spatial/index.js",
      "require": "./dist/spatial/index.cjs"
    },
    "./annotations": {
      "types": "./dist/annotations/index.d.ts",
      "import": "./dist/annotations/index.js",
      "require": "./dist/annotations/index.cjs"
    },
    "./builtins": {
      "types": "./dist/builtins/index.d.ts",
      "import": "./dist/builtins/index.js",
      "require": "./dist/builtins/index.cjs"
    },
    "./legend": {
      "types": "./dist/legend/index.d.ts",
      "import": "./dist/legend/index.js",
      "require": "./dist/legend/index.cjs"
    },
    "./performance": {
      "types": "./dist/performance/index.d.ts",
      "import": "./dist/performance/index.js",
      "require": "./dist/performance/index.cjs"
    },
    "./accessibility": {
      "types": "./dist/accessibility/index.d.ts",
      "import": "./dist/accessibility/index.js",
      "require": "./dist/accessibility/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "rbush": "^4.0.1"
  },
  "peerDependencies": {
    "@rail-schematic-viz/core": "^0.1.0",
    "@rail-schematic-viz/layout": "^0.1.0"
  },
  "devDependencies": {
    "@rail-schematic-viz/core": "file:../..",
    "@rail-schematic-viz/layout": "file:../layout",
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "fast-check": "^4.3.0",
    "tsup": "^8.5.0",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4"
  }
}
