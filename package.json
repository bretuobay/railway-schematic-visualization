{
  "name": "@rail-schematic-viz/core",
  "version": "0.1.0",
  "description": "Core data model, parsers, coordinate systems, and rendering primitives for railway schematic visualization.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./builder": {
      "types": "./dist/builder/index.d.ts",
      "import": "./dist/builder/index.js",
      "require": "./dist/builder/index.cjs"
    },
    "./coordinates": {
      "types": "./dist/coordinates/index.d.ts",
      "import": "./dist/coordinates/index.js",
      "require": "./dist/coordinates/index.cjs"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js",
      "require": "./dist/errors/index.cjs"
    },
    "./parsers": {
      "types": "./dist/parsers/index.d.ts",
      "import": "./dist/parsers/index.js",
      "require": "./dist/parsers/index.cjs"
    },
    "./renderer": {
      "types": "./dist/renderer/index.d.ts",
      "import": "./dist/renderer/index.js",
      "require": "./dist/renderer/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "build:workspaces": "npm run build --workspaces --if-present",
    "check": "node scripts/check-workspaces.mjs . @rail-schematic-viz/layout @rail-schematic-viz/overlays @rail-schematic-viz/adapters-shared @rail-schematic-viz/react @rail-schematic-viz/vue @rail-schematic-viz/web-component",
    "check:build": "node scripts/check-workspaces.mjs --step build . @rail-schematic-viz/layout @rail-schematic-viz/overlays @rail-schematic-viz/adapters-shared @rail-schematic-viz/react @rail-schematic-viz/vue @rail-schematic-viz/web-component",
    "check:phase4": "node scripts/check-workspaces.mjs @rail-schematic-viz/adapters-shared @rail-schematic-viz/react @rail-schematic-viz/vue @rail-schematic-viz/web-component",
    "check:test": "node scripts/check-workspaces.mjs --step test:coverage . @rail-schematic-viz/layout @rail-schematic-viz/overlays @rail-schematic-viz/adapters-shared @rail-schematic-viz/react @rail-schematic-viz/vue @rail-schematic-viz/web-component",
    "check:typecheck": "node scripts/check-workspaces.mjs --step typecheck . @rail-schematic-viz/layout @rail-schematic-viz/overlays @rail-schematic-viz/adapters-shared @rail-schematic-viz/react @rail-schematic-viz/vue @rail-schematic-viz/web-component",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run --passWithNoTests",
    "test:workspaces": "npm run test:run --workspaces --if-present",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:workspaces": "npm run typecheck --workspaces --if-present"
  },
  "keywords": [
    "railway",
    "schematic",
    "visualization",
    "d3",
    "railml"
  ],
  "license": "MIT",
  "dependencies": {
    "d3": "^7.9.0",
    "fast-xml-parser": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "fast-check": "^4.3.0",
    "tsup": "^8.5.0",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4"
  }
}
