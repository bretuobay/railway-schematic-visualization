{
  "name": "@rail-schematic-viz/core",
  "version": "0.1.0",
  "description": "Core data model, parsers, coordinate systems, and rendering primitives for railway schematic visualization.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "browser": "./dist/index.umd.js",
  "unpkg": "./dist/index.umd.js",
  "jsdelivr": "./dist/index.umd.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "rail-schematic-viz": "./bin/rail-schematic-viz.mjs"
  },
  "files": [
    "bin",
    "dist",
    "schemas"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./builder": {
      "types": "./dist/builder/index.d.ts",
      "import": "./dist/builder/index.js",
      "require": "./dist/builder/index.cjs"
    },
    "./coordinates": {
      "types": "./dist/coordinates/index.d.ts",
      "import": "./dist/coordinates/index.js",
      "require": "./dist/coordinates/index.cjs"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js",
      "require": "./dist/errors/index.cjs"
    },
    "./parsers": {
      "types": "./dist/parsers/index.d.ts",
      "import": "./dist/parsers/index.js",
      "require": "./dist/parsers/index.cjs"
    },
    "./renderer": {
      "types": "./dist/renderer/index.d.ts",
      "import": "./dist/renderer/index.js",
      "require": "./dist/renderer/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./schema": "./schemas/rail-schematic-json-schema.v0.1.0.json"
  },
  "imports": {
    "#rail-schematic-schema": "./schemas/rail-schematic-json-schema.v0.1.0.json"
  },
  "scripts": {
    "analyze:bundles": "node scripts/analyze-bundles.mjs",
    "bench:render": "node benchmarks/rendering.benchmark.mjs",
    "build": "tsup --config tsup.config.ts && node scripts/generate-umd.mjs",
    "build:workspaces": "npm run build --workspaces --if-present",
    "check": "node scripts/check-workspaces.mjs --preset all && npm run check:bundles && npm run check:distribution",
    "check:build": "node scripts/check-workspaces.mjs --step build --preset all",
    "check:browser-infra": "vitest run src/browser-compatibility.test.ts src/testing-infrastructure.test.ts",
    "check:bundles": "node scripts/analyze-bundles.mjs",
    "check:ci": "node scripts/check-ci-pipeline.mjs && vitest run src/ci-pipeline.test.ts",
    "check:conformance": "vitest run src/spec-conformance-audit.test.ts",
    "check:docs-site": "vitest run src/docs-site.test.ts",
    "check:distribution": "node scripts/check-distribution.mjs",
    "check:phase4": "node scripts/check-workspaces.mjs --preset phase4",
    "check:phase5": "node scripts/check-workspaces.mjs --preset phase5",
    "check:release-dry-run": "node scripts/run-release-dry-run.mjs",
    "check:runtime": "node scripts/check-production-runtime.mjs",
    "check:signoff": "npm run check && npm run check:conformance && npm run check:release-dry-run && npm run check:runtime",
    "check:storybook": "vitest run src/storybook.test.ts src/storybook-screenshots.test.ts",
    "check:test": "node scripts/check-workspaces.mjs --step test:coverage --preset all",
    "check:typecheck": "node scripts/check-workspaces.mjs --step typecheck --preset all && npm run test:types",
    "docs:build": "node scripts/run-docs-site.mjs build",
    "docs:dev": "node scripts/run-docs-site.mjs dev",
    "docs:preview": "node scripts/run-docs-site.mjs preview",
    "docs:artifact": "node scripts/prepare-docs-artifact.mjs .artifacts/pages",
    "release:manifest": "node scripts/create-release-manifest.mjs",
    "release:notes": "node scripts/release-notes.mjs",
    "storybook": "node scripts/run-storybook.mjs dev",
    "storybook:build": "node scripts/run-storybook.mjs build",
    "storybook:screenshots": "npm run storybook:build && node scripts/capture-storybook-screenshots.mjs",
    "test": "vitest",
    "test:browser": "node scripts/run-browser-tests.mjs --grep-invert @visual",
    "test:coverage": "vitest run --coverage",
    "test:types": "tsc --noEmit -p tsconfig.typespec.json",
    "test:run": "vitest run --passWithNoTests",
    "test:visual": "node scripts/run-browser-tests.mjs --grep @visual --project chrome",
    "test:workspaces": "npm run test:run --workspaces --if-present",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:workspaces": "npm run typecheck --workspaces --if-present"
  },
  "keywords": [
    "railway",
    "schematic",
    "visualization",
    "d3",
    "railml"
  ],
  "license": "MIT",
  "homepage": "https://rail-schematic-viz.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/rail-schematic-viz/rail-schematic-viz.git"
  },
  "bugs": {
    "url": "https://github.com/rail-schematic-viz/rail-schematic-viz/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "fast-xml-parser": "^5.4.1"
  },
  "peerDependencies": {
    "d3": "^7.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/html-vite": "^8.6.14",
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "d3": "^7.9.0",
    "fast-check": "^4.3.0",
    "storybook": "^8.6.14",
    "tsup": "^8.5.0",
    "typescript": "~5.9.3",
    "vite": "^5.4.21",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4"
  }
}
